NEXT_PUBLIC_SUPABASE_URL=https://aqrnbxxtqdpqpuhtujsh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Single user (production default)
ALLOWED_LOGIN=lserlach
ALLOWED_EMAIL=lserlach@gmail.com
AUTH_PASSWORD=change-this-to-a-strong-password

# Multiple users (local dev). When set, overrides ALLOWED_* above.
# Example with prod user + local test user:
# AUTH_USERS=[{"login":"lserlach","email":"lserlach@gmail.com","password":"your-password"},{"login":"test","email":"test@health-tracker.app","password":"HealthTracker_Test_2026"}]
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (generate: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:lserlach@gmail.com

# Vercel Cron auth (any random secret)
CRON_SECRET=change-this-cron-secret

# Reminder timezone (optional)
REMINDER_TIMEZONE=Europe/Moscow
REMINDER_TZ_OFFSET=+03:00
